# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── RAG / Vector Store ───────────────────────────────
VECTOR_STORE_PATH=./data/vectorstore
OPENSTAX_DATA_PATH=./data/openstax
EMBEDDING_MODEL=text-embedding-3-small

# ── Desmos ────────────────────────────────────────────
DESMOS_API_KEY=your-desmos-api-key-here

# ── Google Custom Search ─────────────────────────────
# Get API Key: https://console.cloud.google.com/apis/credentials
# Get Search Engine ID: https://programmablesearchengine.google.com/
# See GOOGLE_SEARCH_SETUP.md for detailed instructions
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# ── Dev Mode ─────────────────────────────────────────
DEV_MODE=false

# ── Phone / Tablet Testing (WiFi) ────────────────────
# Set to your machine's local IP so physical devices can reach the backend.
# Find it with: ipconfig (Windows) or ifconfig (Mac/Linux)
# Example: LOCAL_IP=192.168.1.42
LOCAL_IP=
